# === video-pipeline ===

# Dependencies
node_modules/

# TypeScript build artifacts
dist/
*.tsbuildinfo

# Runtime output (regenerated by `npm run render`)
output/

# Generated assets (re-created by the pipeline: matte / image fetch / etc.)
assets/generated/
assets/matted/

# Per-project render outputs — large, regenerable binaries
projects/*/renders/
projects/*/scenes/
projects/*/vendor/

# Large downloaded reference media (source videos, not project source)
input/ref/

# Personal voice samples (user audio, regenerable)
assets/voice-samples/

# Secrets — keys live in env / ~/.video-toolkit/providers.json / Keychain, never here.
# This is belt-and-suspenders in case a local override file is ever added.
.env
.env.*
*.key
*.pem
providers.json

# Logs / cache / temp
*.log
logs/
.cache/
tmp/
.tmp/

# Editor / OS cruft
.DS_Store
*.swp
.idea/
.vscode/
